{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./build",

    "module": "nodenext",
    "moduleResolution": "nodenext",

    "target": "esnext",
    "types": ["node", "express", "multer"],

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "strict": true,

    "skipLibCheck": true,

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "build", "scripts", "src/tests"]
}